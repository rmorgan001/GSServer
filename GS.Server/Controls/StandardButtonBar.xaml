<UserControl x:Class="GS.Server.Controls.StandardButtonBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:componentModel="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:deviceInterface="clr-namespace:ASCOM.DeviceInterface;assembly=ASCOM.DeviceInterfaces"
             xmlns:domain="clr-namespace:GS.Server.Domain"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:skyTelescope="clr-namespace:GS.Server.SkyTelescope"
             mc:Ignorable="d">
    <UserControl.Resources>
        <domain:ComparisonConverter x:Key="Compare" />
        <domain:BoolToVisConverter x:Key="BoolToVis" />
        <domain:BoolToVisClapConverter x:Key="BoolToClap" />
        <CollectionViewSource x:Key="SortedParkPositions" Source="{Binding ParkPositions}">
            <CollectionViewSource.SortDescriptions>
                <componentModel:SortDescription Direction="Ascending" PropertyName="Name" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>
    <StackPanel HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Orientation="Vertical">
        <Button Width="20"
                Height="20"
                Margin="5,0,0,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                HorizontalContentAlignment="Left"
                VerticalContentAlignment="Top"
                Command="{Binding OpenButtonsWindowCmd}"
                Style="{StaticResource MaterialDesignRaisedAccentButton}"
                ToolTip="{StaticResource hcOpenWin}"
                Visibility="{Binding ButtonsWinVisibility, Converter={StaticResource BoolToVis}}">
            <md:PackIcon Margin="-14,-2,0,0" Kind="OpenInNew" />
        </Button>
        <ComboBox Width="120"
                  MaxWidth="120"
                  md:HintAssist.Hint="{StaticResource btnTipParkPos}"
                  IsEditable="False"
                  IsSynchronizedWithCurrentItem="True"
                  ItemsSource="{Binding Source={StaticResource SortedParkPositions}}"
                  SelectedItem="{Binding ParkSelection, Mode=TwoWay}"
                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                  ToolTip="{StaticResource btnTipParkPos}">
            <ComboBox.ItemTemplate>
                <DataTemplate DataType="skyTelescope:ParkPosition">
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <md:DialogHost VerticalAlignment="Bottom"
                       CloseOnClickAway="True"
                       DialogContent="{Binding ParkContent}"
                       IsOpen="{Binding IsParkDialogOpen}">
            <md:Badged Badge="{Binding ParkBadgeContent}" BadgePlacementMode="Right">
                <Button Width="105"
                        Height="25"
                        Margin="0,5,0,0"
                        Padding="-5"
                        HorizontalAlignment="Left"
                        Command="{Binding OpenParkDialogCmd}"
                        Content="{Binding ParkButtonContent}"
                        Style="{StaticResource MaterialDesignRaisedDarkButton}"
                        ToolTip="{StaticResource btnTipPark}" />
            </md:Badged>
        </md:DialogHost>
        <md:DialogHost VerticalAlignment="Bottom"
                       CloseOnClickAway="True"
                       DialogContent="{Binding HomeContent}"
                       IsOpen="{Binding IsHomeDialogOpen}">
            <md:Badged Badge="{Binding HomeBadgeContent}" BadgePlacementMode="Right">
                <Button Width="105"
                        Height="25"
                        Margin="0,3,0,0"
                        Padding="-5"
                        HorizontalAlignment="Left"
                        Command="{Binding OpenHomeDialogCmd}"
                        Content="{StaticResource btnHome}"
                        Style="{StaticResource MaterialDesignRaisedDarkButton}"
                        ToolTip="{StaticResource btnTipHome}" />
            </md:Badged>
        </md:DialogHost>
        <Button Width="105"
                Height="25"
                Margin="0,3,0,0"
                Padding="-5"
                HorizontalAlignment="Left"
                Command="{Binding ClickStopCommand}"
                Content="{StaticResource btnStop}"
                Style="{StaticResource MaterialDesignRaisedDarkButton}"
                ToolTip="{StaticResource btnTipStop}" />
        <StackPanel Orientation="Horizontal">
            <md:PopupBox Margin="-14,0,-10,0" StaysOpen="False">
                <GroupBox Margin="0,0,5,0" Header="Tracking Rate">
                    <StackPanel Orientation="Vertical">
                        <RadioButton Margin="5"
                                     Content="{StaticResource skySidereal}"
                                     GroupName="tr"
                                     IsChecked="{Binding Path=TrackingRate, Converter={StaticResource Compare}, ConverterParameter={x:Static deviceInterface:DriveRates.driveSidereal}}"
                                     Style="{StaticResource MaterialDesignRadioButton}" />
                        <RadioButton Margin="5"
                                     Content="{StaticResource skyLunar}"
                                     GroupName="tr"
                                     IsChecked="{Binding Path=TrackingRate, Converter={StaticResource Compare}, ConverterParameter={x:Static deviceInterface:DriveRates.driveLunar}}"
                                     Style="{StaticResource MaterialDesignRadioButton}" />
                        <RadioButton Margin="5"
                                     Content="{StaticResource skySolar}"
                                     GroupName="tr"
                                     IsChecked="{Binding Path=TrackingRate, Converter={StaticResource Compare}, ConverterParameter={x:Static deviceInterface:DriveRates.driveSolar}}"
                                     Style="{StaticResource MaterialDesignRadioButton}" />
                        <RadioButton Margin="5"
                                     Content="{StaticResource skyKing}"
                                     GroupName="tr"
                                     IsChecked="{Binding Path=TrackingRate, Converter={StaticResource Compare}, ConverterParameter={x:Static deviceInterface:DriveRates.driveKing}}"
                                     Style="{StaticResource MaterialDesignRadioButton}" />
                    </StackPanel>
                </GroupBox>
            </md:PopupBox>
            <md:Badged Badge="{Binding TrackingBadgeContent}" BadgePlacementMode="Right">
                <md:Badged.Style>
                    <Style TargetType="md:Badged">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMoveAxisActive}" Value="True">
                                <Setter Property="BadgeBackground" Value="{StaticResource SecondaryHueMidBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </md:Badged.Style>
                <Button Width="95"
                        Height="25"
                        Margin="0,3,0,0"
                        Padding="-5"
                        HorizontalAlignment="Left"
                        Command="{Binding ClickTrackingCommand}"
                        Content="{StaticResource btnTracking}"
                        Style="{StaticResource MaterialDesignRaisedDarkButton}"
                        ToolTip="{StaticResource btnTipTracking}" />
            </md:Badged>
        </StackPanel>
        <md:DialogHost VerticalAlignment="Bottom"
                       CloseOnClickAway="True"
                       DialogContent="{Binding HomeResetContent}"
                       IsOpen="{Binding IsHomeResetDialogOpen}">
            <Button Width="105"
                    Height="25"
                    Margin="0,3,0,0"
                    Padding="-5"
                    HorizontalAlignment="Left"
                    Command="{Binding OpenReSyncDialogCmd}"
                    Content="{StaticResource btnReSync}"
                    Style="{StaticResource MaterialDesignRaisedDarkButton}"
                    ToolTip="{StaticResource btnTipSetHome}" />
        </md:DialogHost>
        <md:DialogHost VerticalAlignment="Bottom"
                       CloseOnClickAway="True"
                       DialogContent="{Binding FlipContent}"
                       IsOpen="{Binding IsFlipDialogOpen}">
            <Button Width="105"
                    Height="25"
                    Margin="0,3,0,0"
                    Padding="-5"
                    HorizontalAlignment="Left"
                    Command="{Binding OpenFlipDialogCommand}"
                    Content="{Binding FlipButtonContent}"
                    Style="{StaticResource MaterialDesignRaisedDarkButton}"
                    ToolTip="{Binding FlipButtonTip}" />
        </md:DialogHost>
        <md:DialogHost VerticalAlignment="Bottom"
                       DialogContent="{Binding AutoHomeContent}"
                       IsOpen="{Binding IsAutoHomeDialogOpen}">
            <Button Width="105"
                    Height="25"
                    Margin="0,3,0,0"
                    Padding="-5"
                    HorizontalAlignment="Left"
                    Command="{Binding OpenAutoHomeDialogCommand}"
                    Content="{StaticResource btnAutoHome}"
                    IsEnabled="{Binding AutoHomeEnabled}"
                    Style="{StaticResource MaterialDesignRaisedDarkButton}"
                    ToolTip="{StaticResource btnAutoHome}" />
        </md:DialogHost>
        <md:DialogHost VerticalAlignment="Bottom"
                       CloseOnClickAway="True"
                       DialogContent="{Binding SchedulerContent}"
                       IsOpen="{Binding IsSchedulerDialogOpen}">
            <md:Badged Badge="{Binding SchedulerBadgeContent}" BadgePlacementMode="Right">
                <Button Width="105"
                        Height="25"
                        Margin="0,3,0,0"
                        Padding="-5"
                        HorizontalAlignment="Left"
                        Command="{Binding OpenSchedulerDialogCmd}"
                        Content="{StaticResource btnScheduler}"
                        Style="{StaticResource MaterialDesignRaisedDarkButton}"
                        ToolTip="{StaticResource btnTipScheduler}"
                        Visibility="{Binding SchedulerShow, Converter={StaticResource BoolToClap}}" />
            </md:Badged>
        </md:DialogHost>
        <StackPanel Orientation="Horizontal">
            <Button Padding="-9"
                    Command="{Binding OpenLimitDialogCommand}"
                    IsEnabled="{Binding TrackingLimitSettingsEnable}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    ToolTip="{StaticResource botTipAxisLimit}">
                <md:PackIcon Width="28"
                             Height="30"
                             Margin="-2,0,1,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Kind="EllipsisVertical" />
            </Button>
            <md:Badged Badge="{Binding LimitsBadgeContent}" BadgePlacementMode="Right">
                <md:Badged.Style>
                    <Style TargetType="md:Badged">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLimits}" Value="True">
                                <Setter Property="BadgeBackground" Value="{StaticResource SecondaryHueMidBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </md:Badged.Style>
                <Button Width="96"
                        Height="25"
                        Margin="0,3,0,0"
                        Padding="-5"
                        HorizontalAlignment="Left"
                        Command="{Binding ClickLimitsCommand}"
                        Content="{StaticResource btnLimits}"
                        Style="{StaticResource MaterialDesignRaisedDarkButton}"
                        ToolTip="{StaticResource btnLimits}" />
            </md:Badged>
        </StackPanel>
        <!--<md:Badged Badge="{Binding PecBadgeContent}"
                   BadgePlacementMode="Right"
                   Visibility="{Binding PecShow, Converter={StaticResource BoolToClap}}">
            <Button Width="100"
                    Height="25"
                    Margin="5,6,0,0"
                    Padding="-5"
                    HorizontalAlignment="Left"
                    Command="{Binding ClickPecOnCmd}"
                    Content="{StaticResource Pec}"
                    Style="{StaticResource MaterialDesignRaisedDarkButton}"
                    ToolTip="{StaticResource Pec}" />
        </md:Badged>-->
    </StackPanel>
</UserControl>
