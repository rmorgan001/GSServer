<UserControl x:Class="GS.Server.Controls.AltAzGauges"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:skyTelescope="clr-namespace:GS.Server.SkyTelescope"
             xmlns:wpf="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             d:DataContext="{d:DesignInstance skyTelescope:SkyTelescopeVm}"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource MaterialDesignToolBarBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0"
                    Margin="5"
                    Orientation="Horizontal">
            <TextBlock Text=" " />
        </StackPanel>
        <Path Grid.Row="1"
              Width="150"
              Stretch="Fill"
              Stroke="{StaticResource PrimaryHueLightBrush}"
              StrokeThickness=".5">
            <Path.Data>
                <LineGeometry StartPoint="0,1" EndPoint="1,1" />
            </Path.Data>
        </Path>
        <Path Grid.Row="2"
              Width="150"
              Stretch="Fill"
              Stroke="{StaticResource PrimaryHueLightBrush}"
              StrokeThickness=".5">
            <Path.Data>
                <LineGeometry StartPoint="0,1" EndPoint="1,1" />
            </Path.Data>
        </Path>
        <wpf:AngularGauge Grid.Row="1"
                          Margin="5"
                          FontSize="1"
                          Foreground="{StaticResource MaterialDesignTextFieldBoxHoverBackground}"
                          FromValue="0"
                          NeedleFill="{StaticResource SecondaryHueMidBrush}"
                          SectionsInnerRadius=".6"
                          TicksStrokeThickness="0"
                          ToValue="360"
                          Wedge="360"
                          Value="{Binding AzGauge}">
            <wpf:AngularGauge.Sections>
                <wpf:AngularSection Fill="{StaticResource MaterialDesignTextFieldBoxHoverBackground}"
                                    FromValue="0"
                                    ToValue="360" />
            </wpf:AngularGauge.Sections>
            <wpf:AngularGauge.RenderTransform>
                <RotateTransform Angle="180" CenterX="120" CenterY="73" />
            </wpf:AngularGauge.RenderTransform>
        </wpf:AngularGauge>
        <TextBlock Grid.Row="1"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   FontWeight="Bold"
                   Text="{Binding AzGauge, StringFormat=N2}" />
        <TextBlock Grid.Row="1"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   FontWeight="Bold"
                   Text="{StaticResource lbAz}" />
        <TextBlock Grid.Row="1"
                   Margin="0,0,10,0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   Text="{Binding RaLabelRight}" />
        <TextBlock Grid.Row="1"
                   Margin="10,0,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   Text="{Binding RaLabelLeft}" />
        <wpf:AngularGauge Grid.Row="2"
                          Margin="5"
                          FontSize="1"
                          Foreground="{StaticResource MaterialDesignTextFieldBoxHoverBackground}"
                          FromValue="-90"
                          NeedleFill="{StaticResource SecondaryHueMidBrush}"
                          RenderTransformOrigin="0.5,0.5"
                          SectionsInnerRadius=".6"
                          TicksStrokeThickness="0"
                          ToValue="90"
                          Wedge="180"
                          Value="{Binding AltGauge}">
            <wpf:AngularGauge.RenderTransform>
                <RotateTransform Angle="90" />
            </wpf:AngularGauge.RenderTransform>
            <wpf:AngularGauge.Sections>
                <wpf:AngularSection Fill="{StaticResource MaterialDesignTextFieldBoxHoverBackground}"
                                    FromValue="-90"
                                    ToValue="90" />
            </wpf:AngularGauge.Sections>
        </wpf:AngularGauge>
        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   FontWeight="Bold"
                   Text="{Binding Alt, StringFormat=N}" />
        <TextBlock Grid.Row="2"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   FontWeight="Bold"
                   Text="{StaticResource lbAlt}" />
        <TextBlock Grid.Row="2"
                   Margin="0,0,10,0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   Text="{Binding AltLabelRight}" />
        <TextBlock Grid.Row="2"
                   Margin="10,0,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   Text="{Binding AltLabelLeft}" />
    </Grid>
</UserControl>
