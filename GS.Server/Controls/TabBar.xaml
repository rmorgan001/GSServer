<UserControl x:Class="GS.Server.Controls.TabBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:main="clr-namespace:GS.Server.Main"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance main:MainWindowVm}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <md:ColorZone Mode="PrimaryDark">
        <ScrollViewer FlowDirection="LeftToRight"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>
                <Button Grid.Column="0"
                        MinWidth="0"
                        Padding="10,0,0,0"
                        Command="{Binding ResetWindowCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        ToolTip="{StaticResource tabWindowFlip}">
                    <md:PackIcon Width="20"
                                 Height="20"
                                 Kind="Resize" />
                </Button>
                <RadioButton Grid.Column="1"
                             MinWidth="0"
                             Padding="10,0,10,0"
                             Content="{StaticResource tabMain}"
                             FontSize="16"
                             IsChecked="{Binding SkyWatcherVmRadio}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Visibility="{Binding Path=SkyWatcherRadioVisible, Converter={StaticResource BoolToVis}}" />
                <RadioButton Grid.Column="2"
                             MinWidth="0"
                             Padding="10,0,10,0"
                             Content="{StaticResource tabNotes}"
                             FontSize="16"
                             IsChecked="{Binding NotesVmRadioRadio}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Visibility="{Binding Path=NotesRadioVisible, Converter={StaticResource BoolToVis}}" />
                <RadioButton Grid.Column="3"
                             MinWidth="0"
                             Padding="10,0,10,0"
                             Content="{StaticResource tabOptions}"
                             FontSize="16"
                             IsChecked="{Binding SettingsVmRadio}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Visibility="{Binding Path=SettingsRadioVisible, Converter={StaticResource BoolToVis}}" />
                <RadioButton Grid.Column="4"
                             MinWidth="0"
                             Padding="10,0,10,0"
                             Content="{StaticResource tabGamePad}"
                             FontSize="16"
                             IsChecked="{Binding GamePadVmRadioRadio}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Visibility="{Binding Path=GamePadRadioVisible, Converter={StaticResource BoolToVis}}" />
                <RadioButton Grid.Column="5"
                             MinWidth="0"
                             Padding="10,0,10,0"
                             Content="{StaticResource tabModel3D}"
                             FontSize="16"
                             IsChecked="{Binding Model3DvmRadioRadio}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Visibility="{Binding Path=Model3DRadioVisible, Converter={StaticResource BoolToVis}}" />
                <RadioButton Grid.Column="6"
                             MinWidth="0"
                             Padding="10,0,10,0"
                             Content="{StaticResource Pec}"
                             FontSize="16"
                             IsChecked="{Binding PecVmRadioRadio}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Visibility="{Binding Path=PecRadioVisible, Converter={StaticResource BoolToVis}}" />
                <RadioButton Grid.Column="7"
                             MinWidth="0"
                             Padding="10,0,10,0"
                             Content="{StaticResource tabPlot}"
                             FontSize="16"
                             IsChecked="{Binding PlotVmRadioRadio}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Visibility="{Binding Path=PlotRadioVisible, Converter={StaticResource BoolToVis}}" />
                <RadioButton Grid.Column="8"
                             MinWidth="0"
                             Padding="10,0,10,0"
                             Content="{StaticResource tabPole}"
                             FontSize="16"
                             IsChecked="{Binding PoleLocatorVmRadioRadio}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Visibility="{Binding Path=PoleLocatorRadioVisible, Converter={StaticResource BoolToVis}}" />
                <RadioButton Grid.Column="9"
                             MinWidth="0"
                             Padding="10,0,10,0"
                             Content="{StaticResource tabPulses}"
                             FontSize="16"
                             IsChecked="{Binding PulsesVmRadioRadio}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Visibility="{Binding Path=PulsesRadioVisible, Converter={StaticResource BoolToVis}}" />
                <RadioButton Grid.Column="10"
                             MinWidth="0"
                             Padding="10,0,10,0"
                             Content="{StaticResource tabSnap}"
                             FontSize="16"
                             IsChecked="{Binding SnapVmRadioRadio}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Visibility="{Binding Path=SnapRadioVisible, Converter={StaticResource BoolToVis}}" />
                <RadioButton Grid.Column="11"
                             MinWidth="0"
                             Padding="10,0,10,0"
                             Content="{StaticResource tabFocuser}"
                             FontSize="16"
                             IsChecked="{Binding FocuserVmRadioRadio}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Visibility="{Binding Path=FocuserRadioVisible, Converter={StaticResource BoolToVis}}" />
                <RadioButton Grid.Column="12"
                             MinWidth="0"
                             Padding="10,0,10,0"
                             FontSize="16"
                             IsChecked="{Binding AlignmentVmRadioRadio}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Visibility="{Binding Path=AlignmentRadioVisible, Converter={StaticResource BoolToVis}}">
                    <RadioButton.Content>
                        <md:Badged Badge="{Binding AlignmentAlertBadge}"
                                   BadgeBackground="Gold"
                                   BadgePlacementMode="Right"
                                   ToolTip="{StaticResource aliAlertTooltip}">
                            <TextBlock Text="{StaticResource tabAlignment}" />
                        </md:Badged>
                    </RadioButton.Content>
                </RadioButton>
            </Grid>
        </ScrollViewer>
    </md:ColorZone>
</UserControl>