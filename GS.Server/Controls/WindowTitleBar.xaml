<UserControl x:Class="GS.Server.Controls.WindowTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <StackPanel Background="{StaticResource MaterialDesignBackground}">
        <Grid MinWidth="200">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0"
                       Background="{Binding MountTypeColor}"
                       Dock="Left">
                <StackPanel Margin="5,0,0,0"
                            HorizontalAlignment="Left"
                            Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding TopMost}">
                        <CheckBox.Resources>
                            <!--  ReSharper disable once Xaml.RedundantResource Unchecked state  -->
                            <SolidColorBrush x:Key="MaterialDesignCheckBoxOff" Color="{StaticResource Primary900Foreground}" />
                            <!--  ReSharper disable once Xaml.RedundantResource Checked state  -->
                            <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="{StaticResource Primary900Foreground}" />
                        </CheckBox.Resources>
                    </CheckBox>
                    <TextBlock Margin="5,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource PrimaryHueLightBrush}"
                               Text="{StaticResource titleName}" />
                    <TextBlock Margin="5,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource PrimaryHueLightBrush}"
                               Text="{Binding Version}" />
                    <TextBlock Margin="5,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource PrimaryHueLightBrush}"
                               Text="{Binding MountType, StringFormat={}({0})}" />
                </StackPanel>
            </DockPanel>
            <DockPanel Grid.Column="1" Dock="Right">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock Margin="5,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource PrimaryHueLightBrush}"
                               Text="{StaticResource titleApps}" />
                    <TextBlock Margin="5,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource PrimaryHueLightBrush}"
                               Text="{Binding AppCount}" />
                    <Button Width="30"
                            Height="30"
                            VerticalAlignment="Center"
                            Background="{x:Null}"
                            BorderBrush="{x:Null}"
                            Command="{Binding MinimizeWindowCommand}"
                            Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}">
                        <md:PackIcon Width="25"
                                     Height="25"
                                     VerticalAlignment="Center"
                                     Foreground="{StaticResource PrimaryHueLightBrush}"
                                     Kind="WindowMinimize" />
                    </Button>
                    <Button Width="30"
                            Height="30"
                            VerticalAlignment="Center"
                            Background="{x:Null}"
                            BorderBrush="{x:Null}"
                            Command="{Binding MaximizeWindowCommand}"
                            Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}">
                        <md:PackIcon Width="25"
                                     Height="25"
                                     VerticalAlignment="Center"
                                     Foreground="{StaticResource PrimaryHueLightBrush}"
                                     Kind="WindowMaximize" />
                    </Button>
                    <md:DialogHost HorizontalAlignment="Left"
                                   VerticalAlignment="Bottom"
                                   CloseOnClickAway="True"
                                   DialogContent="{Binding CloseContent}"
                                   IsOpen="{Binding IsCloseDialogOpen}">
                        <Button Width="30"
                                Height="30"
                                VerticalAlignment="Center"
                                Background="{x:Null}"
                                BorderBrush="{x:Null}"
                                Command="{Binding OpenCloseDialogCommand}"
                                Foreground="{StaticResource PrimaryHueLightBrush}"
                                Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}">
                            <md:PackIcon Width="25"
                                         Height="25"
                                         VerticalAlignment="Center"
                                         Foreground="{StaticResource PrimaryHueLightBrush}"
                                         Kind="Power" />
                        </Button>
                    </md:DialogHost>
                </StackPanel>
            </DockPanel>
        </Grid>
    </StackPanel>
</UserControl>
