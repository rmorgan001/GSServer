<UserControl x:Class="GS.Server.Controls.Dialogs.HomeSettingsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:domain="clr-namespace:GS.Shared.Domain;assembly=GS.Shared"
             xmlns:domain1="clr-namespace:GS.Server.Domain"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:skyTelescope="clr-namespace:GS.Server.SkyTelescope"
             d:DataContext="{d:DesignInstance skyTelescope:SkyTelescopeVm}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <domain1:EnumToBoolConverter x:Key="EnumToBool" />
        <domain1:BoolToVisConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <GroupBox Margin="5" Header="{StaticResource homeSettings}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Row="0"
                        Grid.Column="0"
                        Margin="10"
                        VerticalAlignment="Top"
                        Orientation="Vertical">
                <TextBlock Margin="0,0,0,20" Text="{StaticResource lbHomePosition}" />
                <TextBlock Margin="0,0,0,10">
                    <Run Text="{StaticResource lbAxisX}" />
                    <Run Text="{Binding HomeAxisX}" />
                </TextBlock>
                <TextBlock Margin="0,0,0,10" Text="{StaticResource lbAxisY}" />
                <ComboBox MinWidth="150"
                          Margin="0,0,0,10"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding HomeAxisAltList}"
                          ToolTip="{StaticResource lbHomePositionToolTipHome}">
                    <ComboBox.SelectedValue>
                        <Binding Mode="TwoWay"
                                 Path="HomeAxisY"
                                 UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <domain:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                            </Binding.ValidationRules>
                        </Binding>
                    </ComboBox.SelectedValue>
                    <ComboBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ComboBox.ItemsPanel>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        Width="10"
                        VerticalAlignment="Center"
                        Orientation="Vertical">
                <Rectangle Width="2"
                           Height="220"
                           Fill="{StaticResource MaterialDesignDivider}" />
            </StackPanel>
            <StackPanel Grid.Row="0"
                        Grid.Column="2"
                        Margin="10"
                        VerticalAlignment="Top"
                        Orientation="Vertical">
                <TextBlock Margin="0,0,0,20" Text="{StaticResource lbAutoHomePosition}" />
                <RadioButton Content="{StaticResource lbAutoHomeDefault}"
                             GroupName="AutoHomePosition"
                             IsChecked="{Binding SelectedAutoHomePosition, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static skyTelescope:AutoHomePositionType.DefaultGEM}}" />
                <!--<RadioButton GroupName="AutoHomePosition" Margin="0,10,0,0"
                             Content="{StaticResource lbAutoHomePositionPolarRADec}"
                             IsChecked="{Binding SelectedAutoHomePosition, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static skyTelescope:AutoHomePositionType.PolarRADec}}" />-->
                <RadioButton Margin="0,10,0,0"
                             Content="{StaticResource lbAutoHomePositionPolarAzAlt}"
                             GroupName="AutoHomePosition"
                             IsChecked="{Binding SelectedAutoHomePosition, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static skyTelescope:AutoHomePositionType.PolarAzAlt}}" />
                <StackPanel Visibility="{Binding Path=CustomAutoHomeSettingsIsVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <TextBlock Margin="0,20,0,10">
                        <Run Text="{StaticResource lbAxisX}" />
                        <Run Text="{Binding HomeAxisX}" />
                    </TextBlock>
                    <TextBlock Margin="0,0,0,10" Text="{StaticResource lbAxisY}" />
                    <ComboBox MinWidth="150"
                              Margin="0,0,0,10"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding HomeAxisAltList}"
                              ToolTip="{StaticResource lbAutoHomeLocationTooltip}">
                        <ComboBox.SelectedValue>
                            <Binding Mode="TwoWay"
                                     Path="AutoHomeAxisAlt"
                                     UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <domain:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                </Binding.ValidationRules>
                            </Binding>
                        </ComboBox.SelectedValue>
                        <ComboBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ComboBox.ItemsPanel>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Margin="0,5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Command="{Binding AcceptHomeSettingsDialogCmd}"
                        Content="{StaticResource diaAccept}"
                        IsDefault="False"
                        Style="{StaticResource MaterialDesignFlatButton}" />
                <Button Margin="8,0,0,0"
                        Command="{Binding CancelHomeSettingsDialogCmd}"
                        Content="{StaticResource diaCancel}"
                        IsCancel="True"
                        IsDefault="True"
                        Style="{StaticResource MaterialDesignFlatButton}" />
            </StackPanel>
        </Grid>
    </GroupBox>
</UserControl>
