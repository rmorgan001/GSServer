<UserControl x:Class="GS.Server.Controls.TopCoordsBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:skyTelescope="clr-namespace:GS.Server.SkyTelescope"
             d:DataContext="{d:DesignInstance skyTelescope:SkyTelescopeVm}"
             mc:Ignorable="d">
    <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Label Grid.Column="0"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Content="{StaticResource topRaShort}"
               FontSize="16"
               FontWeight="Bold"
               Foreground="{StaticResource SecondaryHueMidBrush}" />
        <Label Grid.Column="1"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Content="{Binding RightAscension, UpdateSourceTrigger=PropertyChanged}"
               FontSize="16"
               FontWeight="Bold">
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="PreviewMouseDoubleClick">
                    <b:InvokeCommandAction Command="{Binding RaDoubleClickCommand}" />
                </b:EventTrigger>
            </b:Interaction.Triggers>
        </Label>
        <Label Grid.Column="2"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Content="{StaticResource topDecShort}"
               FontSize="16"
               FontWeight="Bold"
               Foreground="{StaticResource SecondaryHueMidBrush}" />
        <Label Grid.Column="3"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Content="{Binding Declination, UpdateSourceTrigger=PropertyChanged}"
               FontSize="16"
               FontWeight="Bold" />
        <Label Grid.Column="4"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Content="{StaticResource topAz}"
               FontSize="16"
               FontWeight="Bold"
               Foreground="{StaticResource SecondaryHueMidBrush}" />
        <Label Grid.Column="5"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Content="{Binding Azimuth, UpdateSourceTrigger=PropertyChanged}"
               FontSize="16"
               FontWeight="Bold" />
        <Label Grid.Column="6"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Content="{StaticResource topAlt}"
               FontSize="16"
               FontWeight="Bold"
               Foreground="{StaticResource SecondaryHueMidBrush}" />
        <Label Grid.Column="7"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Content="{Binding Altitude, UpdateSourceTrigger=PropertyChanged}"
               FontSize="16"
               FontWeight="Bold" />
        <Label Grid.Column="8"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Content="{StaticResource topLHA}"
               FontSize="16"
               FontWeight="Bold"
               Foreground="{StaticResource SecondaryHueMidBrush}" />
        <Label Grid.Column="9"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Content="{Binding Lha, UpdateSourceTrigger=PropertyChanged}"
               FontSize="16"
               FontWeight="Bold" />
    </Grid>
</UserControl>
