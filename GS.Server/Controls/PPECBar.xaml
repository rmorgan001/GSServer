<UserControl x:Class="GS.Server.Controls.PPecBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:skyTelescope="clr-namespace:GS.Server.SkyTelescope"
             d:DataContext="{d:DesignInstance skyTelescope:SkyTelescopeVm}"
             mc:Ignorable="d">
    <StackPanel Margin="0,5,0,0"
                VerticalAlignment="Center"
                IsEnabled="{Binding PPecEnabled}"
                Orientation="Horizontal">
        <StackPanel.Style>
            <Style TargetType="StackPanel">
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.3" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="True">
                        <Setter Property="Opacity" Value="1" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </StackPanel.Style>
        <ToggleButton Width="20"
                      Height="20"
                      IsChecked="{Binding PPecOn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Style="{StaticResource MaterialDesignActionLightToggleButton}"
                      ToolTip="{StaticResource ppOnOff}" />
        <Label Content="{StaticResource ppPec}" />
        <ToggleButton Width="20"
                      Height="20"
                      HorizontalAlignment="Center"
                      Command="{Binding OpenPPecDialogCommand}"
                      IsChecked="{Binding PecTrainOn}"
                      Style="{StaticResource MaterialDesignActionLightToggleButton}"
                      ToolTip="{StaticResource ppStartTrainingMode}" />
        <Label Content="{StaticResource ppTraining}" />
        <md:PackIcon Width="20"
                     Height="20"
                     VerticalAlignment="Center"
                     Kind="Timer"
                     ToolTip="{StaticResource ppTipPecTimer}">
            <md:PackIcon.Style>
                <Style TargetType="md:PackIcon">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PecTrainInProgress}" Value="True">
                            <Setter Property="Foreground" Value="LimeGreen" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding PecTrainInProgress}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkBrush}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </md:PackIcon.Style>
        </md:PackIcon>
        <Label Content="{StaticResource ppInTraining}" />
    </StackPanel>
</UserControl>
