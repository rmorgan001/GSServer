<UserControl x:Class="GS.Server.Controls.BottomStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:domain="clr-namespace:GS.Server.Domain"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:skyTelescope="clr-namespace:GS.Server.SkyTelescope"
             d:DataContext="{d:DesignInstance skyTelescope:SkyTelescopeVm}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <domain:BoolToVisClapConverter x:Key="BoolToClap" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Margin="3,0"
                   VerticalAlignment="Center"
                   FontSize="15"
                   Text="{StaticResource botHome}"
                   ToolTip="{StaticResource botTipHome}">
            <TextBlock.Style>
                <Style BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHome}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource SecondaryHueMidBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsHome}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkBrush}" />
                        </DataTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <TextBlock Grid.Column="1"
                   Margin="3,0"
                   VerticalAlignment="Center"
                   FontSize="15"
                   Text="{StaticResource botParked}"
                   ToolTip="{StaticResource botTipParked}">
            <TextBlock.Style>
                <!--<Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignSubheadingTextBlock}">-->
                <Style BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="TextBlock">
                    <Setter Property="Background" Value="Transparent" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding AtPark}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource SecondaryHueMidBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding AtPark}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkBrush}" />
                        </DataTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                        <DataTrigger Binding="{Binding ParkedBlinker}" Value="true">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="5x">
                                        <DoubleAnimation BeginTime="0:0:0"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="1"
                                                         To="0"
                                                         Duration="0:0:0.15" />
                                        <DoubleAnimation BeginTime="0:0:0.15"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0"
                                                         To="1"
                                                         Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <TextBlock Grid.Column="2"
                   Margin="3,0"
                   VerticalAlignment="Center"
                   FontSize="15"
                   Text="{StaticResource botSlewing}"
                   ToolTip="{StaticResource botTipSlewing}">
            <TextBlock.Style>
                <Style BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSlewing}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource SecondaryHueMidBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSlewing}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkBrush}" />
                        </DataTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <TextBlock Name="Tracking"
                   Grid.Column="3"
                   Margin="3,0"
                   VerticalAlignment="Center"
                   FontSize="15"
                   Text="{StaticResource botTracking}"
                   ToolTip="{StaticResource botTipTracking}">
            <TextBlock.Style>
                <Style BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsTracking}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource SecondaryHueMidBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsTracking}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkBrush}" />
                        </DataTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsMoveAxisActive}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource SecondaryHueMidBrush}" />
                            <DataTrigger.EnterActions>
                                <BeginStoryboard Name="TrackingBlinker">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation BeginTime="0:0:0"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="1"
                                                         To="0.25"
                                                         Duration="0:0:1" />
                                        <DoubleAnimation BeginTime="0:0:1"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.25"
                                                         To="1"
                                                         Duration="0:0:1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsMoveAxisActive}" Value="False">
                            <DataTrigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="TrackingBlinker" />
                            </DataTrigger.EnterActions>
                            <Setter Property="Opacity" Value="1.0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <TextBlock Grid.Column="4"
                   Margin="3,0"
                   VerticalAlignment="Center"
                   FontSize="15"
                   Foreground="DimGray"
                   Text="{Binding SideOfPierUI}"
                   ToolTip="{Binding SideOfPierUIToolTip}">
            <TextBlock.Style>
                <Style BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SopBlinker}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkBrush}" />
                        </DataTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                        <DataTrigger Binding="{Binding SopBlinker}" Value="true">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="5x">
                                        <ColorAnimation BeginTime="0:0:0"
                                                        Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                        To="Transparent"
                                                        Duration="0:0:0.15" />
                                        <ColorAnimation BeginTime="0:0:0.15"
                                                        Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                        To="DimGray"
                                                        Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <Path Grid.Column="5"
              Width="25"
              Height="25"
              Margin="3"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Data="{StaticResource PecVector}"
              Stretch="Fill"
              ToolTip="{StaticResource PecStatus}"
              Visibility="{Binding PecShow, Converter={StaticResource BoolToClap}}">
            <Path.Style>
                <Style TargetType="Path">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PecState}" Value="True">
                            <Setter Property="Fill" Value="{StaticResource SecondaryHueMidBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding PecState}" Value="False">
                            <Setter Property="Fill" Value="{StaticResource PrimaryHueDarkBrush}" />
                        </DataTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.1" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Path.Style>
        </Path>
        <Button Grid.Column="6"
                Padding="9"
                Command="{Binding OpenLimitDialogCommand}"
                IsEnabled="{Binding TrackingLimitSettingsEnable}"
                Style="{StaticResource MaterialDesignFlatButton}"
                ToolTip="{StaticResource botTipAxisLimit}">
            <md:PackIcon Width="29"
                         Height="29"
                         Margin="-5"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Kind="WarningCircle">
                <md:PackIcon.Style>
                    <Style TargetType="md:PackIcon">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LimitAlarm}" Value="True">
                                <Setter Property="Foreground" Value="Gold" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LimitAlarm}" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkBrush}" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </md:PackIcon.Style>
            </md:PackIcon>
        </Button>
        <Button Grid.Column="7"
                Padding="9"
                Command="{Binding ClearWarningCommand}"
                Style="{StaticResource MaterialDesignFlatButton}"
                ToolTip="{StaticResource botTipWarnings}">
            <md:PackIcon Width="29"
                         Height="29"
                         Margin="-5"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Kind="WarningBox">
                <md:PackIcon.Style>
                    <Style TargetType="md:PackIcon">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WarningState}" Value="True">
                                <Setter Property="Foreground" Value="Gold" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding WarningState}" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkBrush}" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </md:PackIcon.Style>
            </md:PackIcon>
        </Button>
        <Button Grid.Column="8"
                Padding="9"
                Command="{Binding ClearErrorsCommand}"
                Style="{StaticResource MaterialDesignFlatButton}"
                ToolTip="{StaticResource botTipErrors}">
            <md:PackIcon Width="29"
                         Height="29"
                         Margin="-5"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Kind="AlarmLight">
                <md:PackIcon.Style>
                    <Style TargetType="md:PackIcon">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AlertState}" Value="True">
                                <Setter Property="Foreground" Value="Crimson" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding AlertState}" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkBrush}" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </md:PackIcon.Style>
            </md:PackIcon>
        </Button>
        <Button Grid.Column="9"
                Padding="9"
                Command="{Binding OpenMountInfoDialogCmd}"
                Style="{StaticResource MaterialDesignFlatButton}"
                ToolTip="{StaticResource botTipConnected}">
            <md:PackIcon Width="29"
                         Height="29"
                         Margin="-5"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Kind="Usb"
                         ToolTip="{StaticResource botTipConnected}">
                <md:PackIcon.Style>
                    <Style TargetType="md:PackIcon">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource SecondaryHueMidBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkBrush}" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </md:PackIcon.Style>
            </md:PackIcon>
        </Button>
        <md:PackIcon Grid.Column="10"
                     Width="29"
                     Height="29"
                     Margin="3,0"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource SecondaryHueMidBrush}"
                     Kind="{Binding TrackingRateIcon}"
                     ToolTip="{Binding TrackingRate}">
            <md:PackIcon.Style>
                <Style TargetType="md:PackIcon">
                    <Style.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.3" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </md:PackIcon.Style>
        </md:PackIcon>
        <md:PackIcon Grid.Column="11"
                     Width="29"
                     Height="29"
                     Margin="3,0"
                     VerticalAlignment="Center"
                     Kind="SpeakerWireless"
                     ToolTip="{StaticResource botTipVoice}">
            <md:PackIcon.Style>
                <Style TargetType="md:PackIcon">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding VoiceState}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource SecondaryHueMidBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding VoiceState}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkBrush}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </md:PackIcon.Style>
        </md:PackIcon>
        <md:PackIcon Grid.Column="12"
                     Width="29"
                     Height="29"
                     Margin="3,0"
                     VerticalAlignment="Center"
                     Kind="Monitor"
                     ToolTip="{StaticResource botTipMonitor}">
            <md:PackIcon.Style>
                <Style TargetType="md:PackIcon">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding MonitorState}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource SecondaryHueMidBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding MonitorState}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkBrush}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </md:PackIcon.Style>
        </md:PackIcon>
    </Grid>
</UserControl>



