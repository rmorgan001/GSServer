<UserControl x:Class="GS.Server.Controls.RaDecGauges"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:skyTelescope="clr-namespace:GS.Server.SkyTelescope"
             xmlns:wpf="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             d:DataContext="{d:DesignInstance skyTelescope:SkyTelescopeVm}"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource MaterialDesignToolBarBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0"
                    Margin="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <CheckBox IsChecked="{Binding RaGaugeFlip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="{StaticResource lbOptics}" />
        </StackPanel>
        <Path Grid.Row="1"
              Width="150"
              Stretch="Fill"
              Stroke="{StaticResource PrimaryHueLightBrush}"
              StrokeThickness=".5">
            <Path.Data>
                <LineGeometry StartPoint="0,1" EndPoint="1,1" />
            </Path.Data>
        </Path>
        <Path Grid.Row="2"
              Width="150"
              Stretch="Fill"
              Stroke="{StaticResource PrimaryHueLightBrush}"
              StrokeThickness=".5">
            <Path.Data>
                <LineGeometry StartPoint="0,1" EndPoint="1,1" />
            </Path.Data>
        </Path>
        <wpf:AngularGauge Grid.Row="1"
                          Margin="5"
                          FromValue="270"
                          NeedleFill="{StaticResource SecondaryHueMidBrush}"
                          SectionsInnerRadius=".6"
                          ToValue="-90"
                          Wedge="360"
                          Value="{Binding RaGauge}">
            <wpf:AngularGauge.Sections>
                <wpf:AngularSection Fill="{StaticResource MaterialDesignTextFieldBoxHoverBackground}"
                                    FromValue="270"
                                    ToValue="-90" />
            </wpf:AngularGauge.Sections>
        </wpf:AngularGauge>
        <TextBlock Grid.Row="1"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   FontWeight="Bold"
                   Text="{Binding ActualAxisX}" />
        <TextBlock Grid.Row="1"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   FontWeight="Bold"
                   Text="{StaticResource 3dRaAxis}" />
        <TextBlock Grid.Row="1"
                   Margin="0,0,10,0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   Text="{Binding RaLabelRight}" />
        <TextBlock Grid.Row="1"
                   Margin="10,0,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   Text="{Binding RaLabelLeft}" />
        <wpf:AngularGauge Grid.Row="2"
                          Margin="5"
                          FromValue="270"
                          NeedleFill="{StaticResource SecondaryHueMidBrush}"
                          SectionsInnerRadius=".6"
                          ToValue="-90"
                          Wedge="360"
                          Value="{Binding DecGauge}">
            <wpf:AngularGauge.Sections>
                <wpf:AngularSection Fill="{StaticResource MaterialDesignTextFieldBoxHoverBackground}"
                                    FromValue="270"
                                    ToValue="-90" />
            </wpf:AngularGauge.Sections>
        </wpf:AngularGauge>
        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   FontWeight="Bold"
                   Text="{Binding ActualAxisY}" />
        <TextBlock Grid.Row="2"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   FontWeight="Bold"
                   Text="{StaticResource 3dDecAxis}" />
        <TextBlock Grid.Row="2"
                   Margin="0,0,10,-60"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   Text="{Binding DecLabelRight}" />
        <TextBlock Grid.Row="2"
                   Margin="10,0,0,60"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   Text="{Binding DecLabelLeft}" />
    </Grid>
</UserControl>
