<UserControl x:Class="GS.Server.Controls.HelixViewport3D"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:domain="clr-namespace:GS.Shared.Domain;assembly=GS.Shared"
             xmlns:h="http://helix-toolkit.org/wpf"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:skyTelescope="clr-namespace:GS.Server.SkyTelescope"
             d:DataContext="{d:DesignInstance skyTelescope:SkyTelescopeVm}"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <!--<domain:NullImageConverter x:Key="NullImage" />-->
    </UserControl.Resources>
    <Grid>
        <h:HelixViewport3D x:Name="Viewport3d"
                           ShowCameraInfo="{Binding CameraVis}"
                           ShowCameraTarget="False"
                           ShowViewCube="False"
                           ViewCubeVerticalPosition="Top">
            <h:HelixViewport3D.Camera>
                <PerspectiveCamera x:Name="ViewportCamera" FieldOfView="60" />
            </h:HelixViewport3D.Camera>
            <h:SunLight />
            <h:GridLinesVisual3D Width="5000"
                                 Fill="Black"
                                 Length="5000"
                                 MajorDistance="1000"
                                 MinorDistance="1000"
                                 Thickness="4"
                                 Visible="True" />
            <h:PipeVisual3D Diameter="100"
                            Fill="Black"
                            Point1="0, 0, 0"
                            Point2="0, 0, 50"
                            Visible="True" />
            <h:BoxVisual3D x:Name="LowerPierBeam"
                           Width="{Binding LowerBeamLength}"
                           Height="{Binding BeamWidth}"
                           Center="{Binding LowerBeamMidPoint}"
                           Fill="Black"
                           Length="{Binding BeamWidth}"
                           Visible="True">
                <ModelVisual3D.Transform>
                    <RotateTransform3D CenterX="0"
                                       CenterY="0"
                                       CenterZ="{Binding BeamHalfWidth}">
                        <RotateTransform3D.Rotation>
                            <AxisAngleRotation3D Angle="{Binding LowerBeamAngle}" Axis="1 0 0" />
                        </RotateTransform3D.Rotation>
                    </RotateTransform3D>
                </ModelVisual3D.Transform>
            </h:BoxVisual3D>
            <h:BoxVisual3D x:Name="UpperPierBeam"
                           Width="{Binding BeamWidth}"
                           Height="{Binding UpperBeamLength}"
                           Center="{Binding UpperBeamMidPoint}"
                           Fill="Black"
                           Length="{Binding BeamWidth}"
                           Visible="True">
                <ModelVisual3D.Transform>
                    <RotateTransform3D CenterX="0"
                                       CenterY="0"
                                       CenterZ="{Binding ModelPierHeight}">
                        <RotateTransform3D.Rotation>
                            <AxisAngleRotation3D Angle="{Binding UpperBeamAngle}" Axis="-1 0 0" />
                        </RotateTransform3D.Rotation>
                    </RotateTransform3D>
                </ModelVisual3D.Transform>
            </h:BoxVisual3D>
            <h:PieSliceVisual3D Center="0, 0, 5"
                                EndAngle="{Binding PierSideIndicatorEndAngle}"
                                Fill="{StaticResource SecondaryHueMidBrush}"
                                InnerRadius="300"
                                OuterRadius="350"
                                StartAngle="{Binding PierSideIndicatorStartAngle}" />
            <h:HelixVisual3D Content="{Binding Model}">
                <h:HelixVisual3D.Transform>
                    <Transform3DGroup>
                        <TranslateTransform3D OffsetX="1"
                                              OffsetY="0"
                                              OffsetZ="0" />
                        <RotateTransform3D CenterX="0"
                                           CenterY="{Binding YAxisCentre}"
                                           CenterZ="525">
                            <RotateTransform3D.Rotation>
                                <AxisAngleRotation3D Angle="{Binding XAxisOffset}" Axis="0 0 1" />
                            </RotateTransform3D.Rotation>
                        </RotateTransform3D>
                        <RotateTransform3D CenterX="0"
                                           CenterY="{Binding YAxisCentre}"
                                           CenterZ="525">
                            <RotateTransform3D.Rotation>
                                <AxisAngleRotation3D Angle="{Binding YAxisOffset}" Axis="0 1 0" />
                            </RotateTransform3D.Rotation>
                        </RotateTransform3D>
                        <RotateTransform3D CenterX="0"
                                           CenterY="{Binding YAxisCentre}"
                                           CenterZ="525">
                            <RotateTransform3D.Rotation>
                                <AxisAngleRotation3D Angle="{Binding ZAxisOffset}" Axis="1 0 0" />
                            </RotateTransform3D.Rotation>
                        </RotateTransform3D>
                    </Transform3DGroup>
                </h:HelixVisual3D.Transform>
            </h:HelixVisual3D>
            <h:BoxVisual3D Width="2000"
                           Height="0"
                           BackMaterial="{Binding Compass, Mode=OneWay}"
                           BottomFace="False"
                           Center="0,0,0"
                           Fill="Transparent"
                           Length="2000"
                           Material="{Binding Compass, Mode=OneWay}" />
        </h:HelixViewport3D>
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Width="20"
                    Height="20"
                    Margin="5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Top"
                    Command="{Binding SaveModelViewCmd}"
                    Style="{StaticResource MaterialDesignRaisedAccentButton}"
                    ToolTip="{StaticResource gpSave}"
                    Visibility="{Binding ModelWinVisibility, Converter={StaticResource BoolToVis}}">
                <materialDesign:PackIcon Margin="-14,-2,0,0" Kind="CompassOutline" />
            </Button>
            <Button Width="20"
                    Height="20"
                    Margin="5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Top"
                    Command="{Binding OpenModelWindowCmd}"
                    Style="{StaticResource MaterialDesignRaisedAccentButton}"
                    ToolTip="{StaticResource hcOpenWin}"
                    Visibility="{Binding ModelWinVisibility, Converter={StaticResource BoolToVis}}">
                <materialDesign:PackIcon Margin="-14,-2,0,0" Kind="OpenInNew" />
            </Button>
            <Button Width="20"
                    Height="20"
                    Margin="5"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Top"
                    Command="{Binding OpenResetViewCmd}"
                    Style="{StaticResource MaterialDesignRaisedAccentButton}"
                    ToolTip="{StaticResource 3dResetView}">
                <materialDesign:PackIcon Margin="-14,-2,0,0" Kind="RelativeScale" />
            </Button>
        </StackPanel>
    </Grid>

</UserControl>
