<UserControl x:Class="GS.Server.Model3D.Model3DV"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:GS.Server.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:domain="clr-namespace:GS.Shared.Domain;assembly=GS.Shared"
             xmlns:enums="clr-namespace:GS.Shared;assembly=GS.Shared"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:model3D="clr-namespace:GS.Server.Model3D"
             d:DataContext="{d:DesignInstance model3D:Model3Dvm}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <md:DialogHost CloseOnClickAway="True"
                   DialogContent="{Binding DialogContent}"
                   IsOpen="{Binding IsDialogOpen}">
        <Grid>
            <md:DrawerHost HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           BorderBrush="{StaticResource MaterialDesignDivider}"
                           BorderThickness="0"
                           IsLeftDrawerOpen="{Binding ElementName=MenuToggleButton, Path=IsChecked}">
                <md:DrawerHost.LeftDrawerContent>
                    <Grid Width="300">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40" />
                            <RowDefinition Height="70" />
                            <RowDefinition Height="30" />
                            <RowDefinition Height="30" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Label HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Content="{StaticResource 3dSettings}"
                               FontSize="18" />
                        <ToggleButton Grid.Row="0"
                                      Margin="5"
                                      HorizontalAlignment="Right"
                                      Command="{x:Static md:DrawerHost.CloseDrawerCommand}"
                                      CommandParameter="{x:Static Dock.Left}"
                                      IsChecked="{Binding ElementName=MenuToggleButton, Path=IsChecked, Mode=TwoWay}"
                                      Style="{StaticResource MaterialDesignHamburgerToggleButton}"
                                      ToolTip="{StaticResource optClose}" />
                        <ComboBox Grid.Row="1"
                                  Width="200"
                                  MinWidth="10"
                                  Margin="20,0,5,20"
                                  HorizontalAlignment="Left"
                                  md:HintAssist.Hint="{StaticResource 3dModelType}"
                                  DropDownOpened="ModelListFilter"
                                  ItemsSource="{Binding Source={domain:EnumBindingSource {x:Type enums:Model3DType}}}"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                  ToolTip="{StaticResource 3dModelType}">
                            <ComboBox.Text>
                                <Binding Mode="TwoWay"
                                         Path="ModelType"
                                         UpdateSourceTrigger="PropertyChanged" />
                            </ComboBox.Text>
                            <ComboBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ComboBox.ItemsPanel>
                        </ComboBox>
                        <Label Grid.Row="2"
                               Margin="15,0,0,0"
                               HorizontalAlignment="Left"
                               Content="{StaticResource optDisplayInterval}" />
                        <StackPanel Grid.Row="3"
                                    Margin="20,0,0,0"
                                    Orientation="Horizontal"
                                    Visibility="Visible">
                            <Label Content="{Binding Interval}" />
                            <Label Margin="5,0,0,0" Content="*" />
                            <ComboBox Margin="5,0,0,0"
                                      ItemsSource="{Binding FactorList}"
                                      Style="{StaticResource MaterialDesignComboBox}">
                                <ComboBox.SelectedItem>
                                    <Binding Mode="TwoWay"
                                             Path="ModelFactor"
                                             UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <domain:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </ComboBox.SelectedItem>
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                            </ComboBox>
                            <Label Margin="5,0,0,0" Content="=" />
                            <Label Margin="5,0,0,0" Content="{Binding IntervalTotal}" />
                        </StackPanel>
                        <StackPanel Grid.Row="4"
                                    Margin="20,0,0,0"
                                    Orientation="Vertical"
                                    Visibility="Hidden">
                            <StackPanel Orientation="Horizontal">
                                <Label Content="X" />
                                <Slider Width="200"
                                        HorizontalAlignment="Left"
                                        Delay="1"
                                        IsEnabled="False"
                                        Maximum="360"
                                        Minimum="-360"
                                        Value="{Binding XAxis}" />
                                <Label Content="{Binding XAxis}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="Y" />
                                <Slider Width="200"
                                        HorizontalAlignment="Left"
                                        Delay="1"
                                        IsEnabled="False"
                                        Maximum="360"
                                        Minimum="-360"
                                        Value="{Binding YAxis}" />
                                <Label Content="{Binding YAxis}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="Z" />
                                <Slider Width="200"
                                        HorizontalAlignment="Left"
                                        Delay="1"
                                        IsEnabled="False"
                                        Maximum="360"
                                        Minimum="-360"
                                        Value="{Binding ZAxis}" />
                                <Label Content="{Binding ZAxis}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </md:DrawerHost.LeftDrawerContent>
                <Grid Margin="5,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Orientation="Horizontal">
                        <ToggleButton x:Name="MenuToggleButton"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      Command="{x:Static md:DrawerHost.OpenDrawerCommand}"
                                      CommandParameter="{x:Static Dock.Left}"
                                      IsChecked="False"
                                      IsHitTestVisible="True"
                                      Style="{StaticResource MaterialDesignHamburgerToggleButton}"
                                      ToolTip="{StaticResource skyOpen}" />
                    </StackPanel>
                    <controls:TopCoordsBar Grid.Row="0"
                                           Grid.Column="0"
                                           HorizontalAlignment="Center"
                                           IsEnabled="{Binding ScreenEnabled}"
                                           Visibility="{Binding TopVis, Converter={StaticResource BoolToVis}}" />
                    <controls:HelixViewport3D Grid.Row="1"
                                              Grid.Column="0"
                                              IsEnabled="{Binding ScreenEnabled}">
                        <controls:HelixViewport3D.Style>
                            <Style TargetType="controls:HelixViewport3D">
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.2" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="True">
                                        <Setter Property="Opacity" Value="1.0" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </controls:HelixViewport3D.Style>
                    </controls:HelixViewport3D>
                    <md:Flipper Grid.Row="1"
                                Grid.Column="0"
                                Margin="10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Style="{DynamicResource MaterialDesignCardFlipper}">
                        <md:Flipper.FrontContent>
                            <Border Margin="3"
                                    Background="{StaticResource MaterialDesignToolBarBackground}"
                                    BorderBrush="DimGray"
                                    BorderThickness="3"
                                    CornerRadius="5"
                                    Opacity=".6">
                                <Grid MinWidth="200" Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="{Binding RaVis, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{StaticResource topRa}" />
                                        <TextBlock Margin="10,0,0,0" Text="{Binding RightAscension, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="{Binding HaVis, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Hour Angle:" />
                                        <TextBlock Margin="10,0,0,0" Text="{Binding Lha, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="{Binding DecVis, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{StaticResource topDec}" />
                                        <TextBlock Margin="10,0,0,0" Text="{Binding Declination, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="3"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="{Binding AzVis, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{StaticResource topAz}" />
                                        <TextBlock Margin="10,0,0,0" Text="{Binding Azimuth, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="4"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="{Binding AltVis, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{StaticResource topAlt}" />
                                        <TextBlock Margin="10,0,0,0" Text="{Binding Altitude, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="5"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="{Binding SideVis, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{StaticResource bugSiderealTime}" />
                                        <TextBlock Margin="10,0,0,0" Text="{Binding SiderealTime, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="6"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="{Binding RaAxisVis, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{StaticResource 3dRaAxis}" />
                                        <TextBlock Margin="10,0,0,0" Text="{Binding ActualAxisX, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="7"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="{Binding DecAxisVis, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{StaticResource 3dDecAxis}" />
                                        <TextBlock Margin="10,0,0,0" Text="{Binding ActualAxisY, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="8"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="{Binding RaAxisVis, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Raw AxisX:" />
                                        <TextBlock Margin="10,0,0,0" Text="{Binding RawAxisX, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="9"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="{Binding DecAxisVis, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Raw AxisY:" />
                                        <TextBlock Margin="10,0,0,0" Text="{Binding RawAxisY, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Button Grid.Row="10"
                                            Command="{x:Static md:Flipper.FlipCommand}"
                                            Content="{StaticResource 3dEdit}"
                                            Style="{StaticResource MaterialDesignFlatButton}" />
                                </Grid>
                            </Border>
                        </md:Flipper.FrontContent>
                        <md:Flipper.BackContent>
                            <Border Margin="3"
                                    Background="{StaticResource MaterialDesignToolBarBackground}"
                                    BorderBrush="DimGray"
                                    BorderThickness="3"
                                    CornerRadius="5"
                                    Opacity=".6">
                                <Grid MinWidth="200" Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <CheckBox Grid.Row="0"
                                              Content="{StaticResource topRa}"
                                              IsChecked="{Binding Path=RaVis}" />
                                    <CheckBox Grid.Row="1"
                                              Content="Local Hour Angle"
                                              IsChecked="{Binding Path=HaVis}" />
                                    <CheckBox Grid.Row="2"
                                              Content="{StaticResource topDec}"
                                              IsChecked="{Binding Path=DecVis}" />
                                    <CheckBox Grid.Row="3"
                                              Content="{StaticResource topAz}"
                                              IsChecked="{Binding Path=AzVis}" />
                                    <CheckBox Grid.Row="4"
                                              Content="{StaticResource topAlt}"
                                              IsChecked="{Binding Path=AltVis}" />
                                    <CheckBox Grid.Row="5"
                                              Content="{StaticResource bugSiderealTime}"
                                              IsChecked="{Binding Path=SideVis}" />
                                    <CheckBox Grid.Row="6"
                                              Content="{StaticResource 3dRaAxis}"
                                              IsChecked="{Binding Path=RaAxisVis}" />
                                    <CheckBox Grid.Row="7"
                                              Content="{StaticResource 3dDecAxis}"
                                              IsChecked="{Binding Path=DecAxisVis}" />
                                    <CheckBox Grid.Row="8"
                                              Content="{StaticResource 3dCamera}"
                                              IsChecked="{Binding Path=CameraVis}" />
                                    <CheckBox Grid.Row="9"
                                              Content="{StaticResource 3dTopBar}"
                                              IsChecked="{Binding Path=TopVis}" />
                                    <Button Grid.Row="10"
                                            HorizontalAlignment="Left"
                                            Command="{x:Static md:Flipper.FlipCommand}"
                                            Style="{StaticResource MaterialDesignToolForegroundButton}">
                                        <md:PackIcon Width="25"
                                                     Height="25"
                                                     HorizontalAlignment="Right"
                                                     Kind="ArrowLeft" />
                                    </Button>
                                </Grid>
                            </Border>
                        </md:Flipper.BackContent>
                    </md:Flipper>
                </Grid>
            </md:DrawerHost>
        </Grid>
    </md:DialogHost>
</UserControl>