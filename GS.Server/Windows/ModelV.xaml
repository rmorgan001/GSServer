<Window x:Class="GS.Server.Windows.ModelV"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GS.Server.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:windows="clr-namespace:GS.Server.Windows"
        Title="{StaticResource 3dModel}"
        Width="{Binding WinWidth}"
        Height="{Binding WinHeight}"
        AllowsTransparency="True"
        ContentRendered="MainWindow_OnContentRendered"
        d:DataContext="{d:DesignInstance windows:ModelVm,
                                         IsDesignTimeCreatable=True}"
        FontFamily="pack://application:,,,/MaterialDesignThemes.Wpf;component/Resources/Roboto/#Roboto"
        FontStretch="Normal"
        ResizeMode="CanResizeWithGrip"
        TextElement.FontSize="14"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextOptions.TextFormattingMode="Display"
        Topmost="{Binding TopMost}"
        WindowStartupLocation="CenterOwner"
        WindowState="{Binding WindowStates}"
        WindowStyle="None"
        mc:Ignorable="d">
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo Description="{StaticResource 3dModel}" />
    </Window.TaskbarItemInfo>
    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <controls:WindowTitleBarBasic Grid.Row="0" />
        <md:DialogHost Grid.Row="1"
                       HorizontalAlignment="Center"
                       Background="Transparent"
                       CloseOnClickAway="True"
                       DialogContent="{Binding DialogContent}"
                       IsOpen="{Binding IsDialogOpen}" />
        <Border Grid.Row="1"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderBrush="DimGray"
                BorderThickness="3"
                CornerRadius="5">
            <Grid IsEnabled="{Binding ScreenEnabled, Mode=OneWay}">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="True">
                                <Setter Property="Opacity" Value="1.0" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <controls:HelixViewport3D Margin="3"
                                          Background="{DynamicResource MaterialDesignPaper}"
                                          IsEnabled="{Binding ScreenEnabled, Mode=OneWay}" />
                <StackPanel HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Background="{DynamicResource MaterialDesignPaper}"
                            Orientation="Horizontal">
                    <Label Content="{StaticResource topRaShort}" />
                    <Label Content="{Binding RightAscension}" Foreground="{StaticResource SecondaryHueMidBrush}" />
                    <Label Content="{StaticResource topDecShort}" />
                    <Label Content="{Binding Declination}" Foreground="{StaticResource SecondaryHueMidBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
