<UserControl x:Class="GS.Server.SkyTelescope.SkyTelescopeV"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:componentModel="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             xmlns:controls="clr-namespace:GS.Server.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:deviceInterface="clr-namespace:ASCOM.DeviceInterface;assembly=ASCOM.DeviceInterfaces"
             xmlns:domain="clr-namespace:GS.Server.Domain"
             xmlns:domain1="clr-namespace:GS.Shared.Domain;assembly=GS.Shared"
             xmlns:enums="clr-namespace:ASCOM.Utilities;assembly=ASCOM.Utilities"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:skyTelescope="clr-namespace:GS.Server.SkyTelescope"
             d:DataContext="{d:DesignInstance skyTelescope:SkyTelescopeVm}"
             mc:Ignorable="d">
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="PreviewKeyDown">
            <b:InvokeCommandAction Command="{Binding PressKeyDownCmd}" PassEventArgsToCommand="True" />
        </b:EventTrigger>
        <b:EventTrigger EventName="PreviewKeyUp">
            <b:InvokeCommandAction Command="{Binding PressKeyReleaseCmd}" PassEventArgsToCommand="True" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    <UserControl.Resources>
        <domain:ComparisonConverter x:Key="Compare" />
        <domain:InverseBooleanConverter x:Key="InvertBool" />
        <domain:EnumToVisibilityConverter x:Key="EnumToVis" />
        <domain:BoolToVisClapConverter x:Key="BoolToVisClap" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <domain1:EnumValueToDescriptionConverter x:Key="EnumToDesc" />
        <CollectionViewSource x:Key="SortedParkPositions" Source="{Binding ParkPositions}">
            <CollectionViewSource.SortDescriptions>
                <componentModel:SortDescription Direction="Ascending" PropertyName="Name" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>
    <md:DialogHost CloseOnClickAway="True"
                   DialogContent="{Binding DialogContent}"
                   IsOpen="{Binding IsDialogOpen}">
        <Grid MinWidth="800">
            <md:DrawerHost HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           BorderBrush="{StaticResource MaterialDesignDivider}"
                           BorderThickness="0"
                           IsLeftDrawerOpen="{Binding OpenSetupDialog}">
                <!--  switched lines for openDialog so COM can open the settings IsLeftDrawerOpen="{Binding OpenSetupDialog}"  -->
                <!--  IsLeftDrawerOpen="{Binding ElementName=MenuToggleButton, Path=IsChecked}"  -->
                <md:DrawerHost.LeftDrawerContent>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid Width="800"
                              Height="420"
                              Margin="10,0,10,0"
                              VerticalAlignment="Top"
                              IsEnabled="{Binding SettingsGridEnabled}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Row="0"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="5">
                                <Label HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Content="{StaticResource skySettings}"
                                       FontSize="18" />
                                <ToggleButton Grid.Row="0"
                                              HorizontalAlignment="Right"
                                              Command="{x:Static md:DrawerHost.CloseDrawerCommand}"
                                              CommandParameter="{x:Static Dock.Left}"
                                              IsChecked="{Binding ElementName=MenuToggleButton, Path=IsChecked}"
                                              Style="{StaticResource MaterialDesignHamburgerToggleButton}"
                                              ToolTip="{StaticResource skyClose}" />
                            </Grid>
                            <DockPanel Grid.Row="1"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="5"
                                       HorizontalAlignment="Left">
                                <ComboBox Width="180"
                                          md:HintAssist.Hint="{StaticResource skyPorts}"
                                          ItemsSource="{Binding Devices, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedItem="{Binding SelectedDevice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                          ToolTip="{StaticResource skyPorts}">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                </ComboBox>
                                <ComboBox Width="100"
                                          Margin="10,0,0,0"
                                          VerticalAlignment="Center"
                                          md:HintAssist.Hint="{StaticResource skyBaud}"
                                          ItemsSource="{Binding Source={domain1:EnumValueBindingSourceExtension {x:Type enums:SerialSpeed}}}"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                          ToolTip="{StaticResource skyBaud}">
                                    <ComboBox.Text>
                                        <Binding Mode="TwoWay"
                                                 Path="BaudRate"
                                                 UpdateSourceTrigger="PropertyChanged" />
                                    </ComboBox.Text>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Mode=OneTime, Converter={StaticResource EnumToDesc}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                </ComboBox>
                                <Button Width="30"
                                        Height="30"
                                        Margin="10,0,0,0"
                                        Command="{Binding ClickWifiCmd}"
                                        Style="{StaticResource MaterialDesignFloatingActionMiniDarkButton}"
                                        ToolTip="Wifi">
                                    <md:PackIcon Width="25"
                                                 Height="25"
                                                 Foreground="{StaticResource PrimaryHueMidBrush}"
                                                 Kind="Wifi" />
                                </Button>
                                <Button Width="30"
                                        Height="30"
                                        Margin="10,0,0,0"
                                        Command="{Binding ClickUsbCmd}"
                                        Style="{StaticResource MaterialDesignFloatingActionMiniDarkButton}"
                                        ToolTip="USB">
                                    <md:PackIcon Width="25"
                                                 Height="25"
                                                 Foreground="{StaticResource PrimaryHueMidBrush}"
                                                 Kind="Usb" />
                                </Button>
                                <ComboBox Width="100"
                                          Margin="10,0,0,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          md:HintAssist.Hint="{StaticResource skyMount}"
                                          ItemsSource="{Binding Source={domain1:EnumValueBindingSourceExtension {x:Type skyTelescope:MountType}}}"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                          ToolTip="{StaticResource skyMount}">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                    <ComboBox.Text>
                                        <Binding Mode="TwoWay"
                                                 Path="Mount"
                                                 UpdateSourceTrigger="PropertyChanged" />
                                    </ComboBox.Text>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Mode=OneTime, Converter={StaticResource EnumToDesc}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <ComboBox Margin="10,0,0,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          md:HintAssist.Hint="{StaticResource skyEquatorial}"
                                          ItemsSource="{Binding Source={domain1:EnumValueBindingSourceExtension {x:Type deviceInterface:EquatorialCoordinateType}}}"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                          ToolTip="{StaticResource skyEquatorial}">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                    <ComboBox.Text>
                                        <Binding Mode="TwoWay"
                                                 Path="EquatorialCoordinateType"
                                                 UpdateSourceTrigger="PropertyChanged" />
                                    </ComboBox.Text>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Mode=OneTime, Converter={StaticResource EnumToDesc}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <ComboBox MinWidth="100"
                                          Margin="10,0,0,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          md:HintAssist.Hint="{StaticResource skyAlignment}"
                                          IsEnabled="True"
                                          ItemsSource="{Binding Source={domain1:EnumValueBindingSourceExtension {x:Type deviceInterface:AlignmentModes}}}"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                          ToolTip="{StaticResource skyAlignment}">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                    <ComboBox.Text>
                                        <Binding Mode="TwoWay"
                                                 Path="AlignmentMode"
                                                 UpdateSourceTrigger="PropertyChanged" />
                                    </ComboBox.Text>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Mode=OneTime, Converter={StaticResource EnumToDesc}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DockPanel>
                            <ComboBox Grid.Row="2"
                                      Grid.Column="0"
                                      MinWidth="10"
                                      Margin="0,0,0,0"
                                      VerticalAlignment="Center"
                                      md:HintAssist.Hint="{StaticResource skyRaGuiding}"
                                      ItemsSource="{Binding GuideRateOffsetList}"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      ToolTip="{StaticResource skyRaGuiding}">
                                <ComboBox.SelectedItem>
                                    <Binding Mode="TwoWay"
                                             Path="GuideRateOffsetX"
                                             UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </ComboBox.SelectedItem>
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                            </ComboBox>
                            <ComboBox Grid.Row="2"
                                      Grid.Column="1"
                                      MinWidth="10"
                                      Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      md:HintAssist.Hint="{StaticResource skyDecGuiding}"
                                      ItemsSource="{Binding GuideRateOffsetList}"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      ToolTip="{StaticResource skyDecGuiding}">
                                <ComboBox.SelectedItem>
                                    <Binding Mode="TwoWay"
                                             Path="GuideRateOffsetY"
                                             UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </ComboBox.SelectedItem>
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                            </ComboBox>
                            <ComboBox Grid.Row="2"
                                      Grid.Column="4"
                                      MinWidth="10"
                                      Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      md:HintAssist.Hint="{StaticResource skyMaxSlew}"
                                      ItemsSource="{Binding MaxSlewRates}"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      ToolTip="{StaticResource skyMaxSlew}">
                                <ComboBox.SelectedItem>
                                    <Binding Mode="TwoWay"
                                             Path="MaxSlewRate"
                                             UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </ComboBox.SelectedItem>
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                            </ComboBox>
                            <ComboBox Grid.Row="2"
                                      Grid.Column="3"
                                      MinWidth="10"
                                      Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      md:HintAssist.Hint="{StaticResource skyFlipAng}"
                                      ItemsSource="{Binding HourAngleLimits}"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      ToolTip="{StaticResource skyFlipAng}">
                                <ComboBox.SelectedItem>
                                    <Binding Mode="TwoWay"
                                             Path="HourAngleLimit"
                                             UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </ComboBox.SelectedItem>
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                            </ComboBox>
                            <ComboBox Grid.Row="3"
                                      Grid.Column="1"
                                      MinWidth="10"
                                      Margin="10,0,5,0"
                                      VerticalAlignment="Center"
                                      md:HintAssist.Hint="{StaticResource skyMinPulseDec}"
                                      ItemsSource="{Binding MinPulseList}"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      ToolTip="{StaticResource skyMinPulseDec}">
                                <ComboBox.SelectedItem>
                                    <Binding Mode="TwoWay"
                                             Path="MinPulseDec"
                                             UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </ComboBox.SelectedItem>
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                            </ComboBox>
                            <ComboBox Grid.Row="4"
                                      Grid.Column="1"
                                      MinWidth="10"
                                      Margin="10,0,5,0"
                                      VerticalAlignment="Center"
                                      md:HintAssist.Hint="{StaticResource skyMinPulseRa}"
                                      ItemsSource="{Binding MinPulseList}"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      ToolTip="{StaticResource skyMinPulseRa}">
                                <ComboBox.SelectedItem>
                                    <Binding Mode="TwoWay"
                                             Path="MinPulseRa"
                                             UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </ComboBox.SelectedItem>
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                            </ComboBox>
                            <ComboBox Grid.Row="3"
                                      Grid.Column="2"
                                      MinWidth="10"
                                      Margin="10,0,5,0"
                                      VerticalAlignment="Center"
                                      md:HintAssist.Hint="{StaticResource skyTracking}"
                                      ItemsSource="{Binding Source={domain1:EnumValueBindingSourceExtension {x:Type deviceInterface:DriveRates}}}"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      ToolTip="{StaticResource skyTracking}">
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                                <ComboBox.Text>
                                    <Binding Mode="TwoWay"
                                             Path="TrackingRate"
                                             UpdateSourceTrigger="PropertyChanged" />
                                </ComboBox.Text>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Mode=OneTime, Converter={StaticResource EnumToDesc}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <ComboBox Grid.Row="3"
                                      Grid.Column="3"
                                      MinWidth="10"
                                      Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      md:HintAssist.Hint="{StaticResource skyPolarLedLevel}"
                                      IsEnabled="{Binding PolarLedLevelEnabled}"
                                      ItemsSource="{Binding PolarLedLevels}"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      ToolTip="{StaticResource skyPolarLedLevel}">
                                <ComboBox.SelectedItem>
                                    <Binding Mode="TwoWay"
                                             Path="PolarLedLevel"
                                             UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </ComboBox.SelectedItem>
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                            </ComboBox>
                            <StackPanel Grid.Row="3"
                                        Grid.Column="4"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                <Button Margin="5,0,5,0"
                                        Command="{Binding OpenCapDialogCmd}"
                                        Foreground="{StaticResource PrimaryHueMidBrush}"
                                        Style="{StaticResource MaterialDesignFloatingActionMiniDarkButton}"
                                        ToolTip="{StaticResource btnCap}">
                                    <md:PackIcon Width="25"
                                                 Height="25"
                                                 Kind="CheckboxMultipleMarked" />
                                </Button>
                                <Button Margin="5,0,5,0"
                                        Command="{Binding OpenGearDialogCommand}"
                                        Style="{StaticResource MaterialDesignFloatingActionMiniDarkButton}"
                                        ToolTip="{StaticResource customGears}">
                                    <md:PackIcon Width="30"
                                                 Height="30"
                                                 Kind="Gearbox">
                                        <md:PackIcon.Style>
                                            <Style TargetType="md:PackIcon">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CustomGearing}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource SecondaryHueMidBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CustomGearing}" Value="False">
                                                        <Setter Property="Foreground" Value="{StaticResource PrimaryHueMidBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </md:PackIcon.Style>
                                    </md:PackIcon>
                                </Button>
                                <Button Margin="5,0,5,0"
                                        Command="{Binding OpenHardwareLimitsWindowCmd}"
                                        Foreground="{StaticResource PrimaryHueMidBrush}"
                                        Style="{StaticResource MaterialDesignFloatingActionMiniDarkButton}"
                                        ToolTip="{StaticResource mhlButtonToolTip}">
                                    <md:PackIcon Width="25"
                                                 Height="25"
                                                 Kind="WifiStrengthOutline" />
                                </Button>
                                <Button Margin="5,0,5,0"
                                        Command="{Binding OpenHomeSettingsDialogCmd}"
                                        Foreground="{StaticResource PrimaryHueMidBrush}"
                                        Style="{StaticResource MaterialDesignFloatingActionMiniDarkButton}"
                                        ToolTip="{StaticResource mhlHomeButtonToolTip}"
                                        Visibility="{Binding HomeSettingsDialogIsVisible, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                                    <md:PackIcon Width="30"
                                                 Height="30"
                                                 Kind="HomeEditOutline" />
                                </Button>
                            </StackPanel>
                            <ComboBox Grid.Row="2"
                                      Grid.Column="2"
                                      MinWidth="10"
                                      Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      md:HintAssist.Hint="{StaticResource skyST4}"
                                      ItemsSource="{Binding St4GuideRates}"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      ToolTip="{StaticResource skyST4}">
                                <ComboBox.SelectedItem>
                                    <Binding Mode="TwoWay"
                                             Path="St4GuideRate"
                                             UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </ComboBox.SelectedItem>
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                            </ComboBox>
                            <StackPanel Grid.Row="5"
                                        Grid.Column="1"
                                        Margin="0,0,0,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                <md:PopupBox Width="24"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Bottom"
                                             IsEnabled="true"
                                             StaysOpen="False"
                                             ToolTip="{StaticResource skyReset}">
                                    <Grid Width="150">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="30" />
                                            <RowDefinition Height="40" />
                                        </Grid.RowDefinitions>
                                        <Label Grid.Row="0"
                                               HorizontalAlignment="Center"
                                               Content="{StaticResource SkyResetDef}" />
                                        <Button Grid.Row="1"
                                                HorizontalAlignment="Center"
                                                Command="{Binding ClickResetSiderealRateCommand}"
                                                Content="{StaticResource diaAccept}"
                                                Style="{StaticResource MaterialDesignRaisedButton}" />
                                    </Grid>
                                </md:PopupBox>
                                <TextBox Width="110"
                                         md:HintAssist.Hint="{StaticResource skySiderealRate}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         ToolTip="{StaticResource skySiderealRate}">
                                    <TextBox.Text>
                                        <Binding Mode="TwoWay"
                                                 Path="SiderealRate"
                                                 UpdateSourceTrigger="LostFocus">
                                            <Binding.ValidationRules>
                                                <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                                <domain:DoubleValidationRule ValidatesOnTargetUpdated="True" />
                                            </Binding.ValidationRules>
                                        </Binding>
                                    </TextBox.Text>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Grid.Row="6"
                                        Grid.Column="1"
                                        Margin="0,0,0,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                <md:PopupBox Width="24"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Bottom"
                                             IsEnabled="true"
                                             StaysOpen="False"
                                             ToolTip="{StaticResource skyReset}">
                                    <Grid Width="150">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="30" />
                                            <RowDefinition Height="40" />
                                        </Grid.RowDefinitions>
                                        <Label Grid.Row="0"
                                               HorizontalAlignment="Center"
                                               Content="{StaticResource SkyResetDef}" />
                                        <Button Grid.Row="1"
                                                HorizontalAlignment="Center"
                                                Command="{Binding ClickResetSolarRateCommand}"
                                                Content="{StaticResource diaAccept}"
                                                Style="{StaticResource MaterialDesignRaisedButton}" />
                                    </Grid>
                                </md:PopupBox>
                                <TextBox Width="110"
                                         md:HintAssist.Hint="{StaticResource skySolarRate}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         ToolTip="{StaticResource skySolarRate}">
                                    <TextBox.Text>
                                        <Binding Mode="TwoWay"
                                                 Path="SolarRate"
                                                 UpdateSourceTrigger="LostFocus">
                                            <Binding.ValidationRules>
                                                <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                                <domain:DoubleValidationRule ValidatesOnTargetUpdated="True" />
                                            </Binding.ValidationRules>
                                        </Binding>
                                    </TextBox.Text>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Grid.Row="7"
                                        Grid.Column="1"
                                        Margin="0,0,0,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                <md:PopupBox Width="24"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Bottom"
                                             IsEnabled="true"
                                             StaysOpen="False"
                                             ToolTip="{StaticResource skyReset}">
                                    <Grid Width="150">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="30" />
                                            <RowDefinition Height="40" />
                                        </Grid.RowDefinitions>
                                        <Label Grid.Row="0"
                                               HorizontalAlignment="Center"
                                               Content="{StaticResource SkyResetDef}" />
                                        <Button Grid.Row="1"
                                                HorizontalAlignment="Center"
                                                Command="{Binding ClickResetLunarRateCommand}"
                                                Content="{StaticResource diaAccept}"
                                                Style="{StaticResource MaterialDesignRaisedButton}" />
                                    </Grid>
                                </md:PopupBox>
                                <TextBox Width="110"
                                         md:HintAssist.Hint="{StaticResource skyLunarRate}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         ToolTip="{StaticResource skyLunarRate}">
                                    <TextBox.Text>
                                        <Binding Mode="TwoWay"
                                                 Path="LunarRate"
                                                 UpdateSourceTrigger="LostFocus">
                                            <Binding.ValidationRules>
                                                <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                                <domain:DoubleValidationRule ValidatesOnTargetUpdated="True" />
                                            </Binding.ValidationRules>
                                        </Binding>
                                    </TextBox.Text>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Grid.Row="8"
                                        Grid.Column="1"
                                        Margin="0,0,0,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                <md:PopupBox Width="24"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Bottom"
                                             IsEnabled="true"
                                             StaysOpen="False"
                                             ToolTip="{StaticResource skyReset}">
                                    <Grid Width="150">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="30" />
                                            <RowDefinition Height="40" />
                                        </Grid.RowDefinitions>
                                        <Label Grid.Row="0"
                                               HorizontalAlignment="Center"
                                               Content="{StaticResource SkyResetDef}" />
                                        <Button Grid.Row="1"
                                                HorizontalAlignment="Center"
                                                Command="{Binding ClickResetKingRateCommand}"
                                                Content="{StaticResource diaAccept}"
                                                Style="{StaticResource MaterialDesignRaisedButton}" />
                                    </Grid>
                                </md:PopupBox>
                                <TextBox Width="110"
                                         md:HintAssist.Hint="{StaticResource skyKingRate}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         ToolTip="{StaticResource skyKingRate}">
                                    <TextBox.Text>
                                        <Binding Mode="TwoWay"
                                                 Path="KingRate"
                                                 UpdateSourceTrigger="LostFocus">
                                            <Binding.ValidationRules>
                                                <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                                <domain:DoubleValidationRule ValidatesOnTargetUpdated="True" />
                                            </Binding.ValidationRules>
                                        </Binding>
                                    </TextBox.Text>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Grid.Row="3"
