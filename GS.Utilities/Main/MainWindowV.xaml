<Window x:Class="GS.Utilities.Main.MainWindowV"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GS.Utilities.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:domain1="clr-namespace:GS.Shared.Domain;assembly=GS.Shared"
        xmlns:main="clr-namespace:GS.Utilities.Main"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:GS.Utilities.Properties"
        Title="GS Utilities"
        Width="{Binding WindowWidth, Source={x:Static properties:Utilities.Default}, Mode=TwoWay}"
        Height="{Binding WindowHeight, Source={x:Static properties:Utilities.Default}, Mode=TwoWay}"
        Background="{DynamicResource MaterialDesignPaper}"
        Closed="MainWindow_OnClosed"
        ContentRendered="MainWindow_OnContentRendered"
        d:DataContext="{d:DesignInstance main:MainWindowVm}"
        FontSize="13"
        Left="{Binding WindowLeft, Source={x:Static properties:Utilities.Default}, Mode=TwoWay}"
        ResizeMode="CanResizeWithGrip"
        TextElement.FontSize="14"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextOptions.TextFormattingMode="Display"
        Top="{Binding WindowTop, Source={x:Static properties:Utilities.Default}, Mode=TwoWay}"
        WindowState="{Binding WindowState, Source={x:Static properties:Utilities.Default}, Mode=TwoWay}"
        WindowStyle="None"
        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>
        <controls:WindowTitleBar Grid.Row="0" />
        <Grid Grid.Row="1">
            <materialDesign:DialogHost CloseOnClickAway="True"
                                       DialogContent="{Binding DialogContent}"
                                       IsOpen="{Binding IsDialogOpen}" />
            <materialDesign:DrawerHost BorderBrush="{DynamicResource MaterialDesignDivider}"
                                       BorderThickness="2"
                                       IsLeftDrawerOpen="{Binding ElementName=MenuToggleButton, Path=IsChecked}">
                <materialDesign:DrawerHost.LeftDrawerContent>
                    <Grid Width="400">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40" />
                            <RowDefinition Height="300" />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0"
                               Grid.Column="0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{DynamicResource PrimaryHueMidBrush}">
                            Settings
                        </Label>
                        <ToggleButton Grid.Row="0"
                                      Grid.Column="0"
                                      Margin="5"
                                      HorizontalAlignment="Right"
                                      Command="{x:Static materialDesign:DrawerHost.CloseDrawerCommand}"
                                      CommandParameter="{x:Static Dock.Left}"
                                      DockPanel.Dock="Top"
                                      IsChecked="{Binding ElementName=MenuToggleButton, Path=IsChecked, Mode=TwoWay}"
                                      Style="{StaticResource MaterialDesignHamburgerToggleButton}" />
                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <ComboBox MinWidth="10"
                                      Margin="20"
                                      HorizontalAlignment="Left"
                                      materialDesign:HintAssist.Hint="{StaticResource optLanguage}"
                                      ItemsSource="{Binding Languages}"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      ToolTip="{StaticResource optLanguage}">
                                <ComboBox.Text>
                                    <Binding Mode="TwoWay"
                                             Path="Lang"
                                             UpdateSourceTrigger="PropertyChanged" />
                                </ComboBox.Text>
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </materialDesign:DrawerHost.LeftDrawerContent>
                <Grid IsEnabled="{Binding ScreenEnabled}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <ToggleButton x:Name="MenuToggleButton"
                                  Grid.Row="0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  Command="{x:Static materialDesign:DrawerHost.OpenDrawerCommand}"
                                  CommandParameter="{x:Static Dock.Left}"
                                  IsChecked="False"
                                  Style="{StaticResource MaterialDesignHamburgerToggleButton}" />
                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Margin="5"
                            VerticalAlignment="Top"
                            BorderBrush="DimGray"
                            BorderThickness="3"
                            CornerRadius="5">
                        <Grid Background="{DynamicResource MaterialDesignToolBarBackground}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="280" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <GroupBox Grid.Row="0"
                                      Margin="5"
                                      Padding="-1">
                                <GroupBox.Header>
                                    <TextBlock HorizontalAlignment="Center"
                                               FontWeight="Bold"
                                               Text="{StaticResource utilGbName}" />
                                </GroupBox.Header>
                                <ListBox BorderThickness="0" ItemsSource="{Binding Folders}">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="Padding" Value="0" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding NameCount}" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>
                            <StackPanel Grid.Row="1"
                                        Margin="5"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal">
                                <materialDesign:DialogHost HorizontalAlignment="Center" CloseOnClickAway="True"
                                                           DialogContent="{Binding DelDialogContent}"
                                                           IsOpen="{Binding IsDelDialogOpen}">
                                    <Button Margin="5"
                                            Command="{Binding OpenDelDialogCommand}"
                                            Content="{DynamicResource utilDelete}"
                                            Style="{StaticResource MaterialDesignRaisedDarkButton}"
                                            ToolTip="{DynamicResource utilDelete}" />
                                </materialDesign:DialogHost>
                                <materialDesign:DialogHost HorizontalAlignment="Center" CloseOnClickAway="True"
                                                           DialogContent="{Binding ZipDialogContent}"
                                                           IsOpen="{Binding IsZipDialogOpen}">
                                    <Button Margin="5"
                                            Command="{Binding OpenZipDialogCommand}"
                                            Content="{DynamicResource utilZip}"
                                            Style="{StaticResource MaterialDesignRaisedDarkButton}"
                                            ToolTip="{DynamicResource utilZip}" />

                                </materialDesign:DialogHost>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Margin="5">
                        <Border BorderBrush="DimGray"
                                BorderThickness="3"
                                CornerRadius="5">
                            <Grid Background="{DynamicResource MaterialDesignToolBarBackground}">
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Margin="5"
                                           VerticalAlignment="Center"
                                           Text="{DynamicResource utilLockTitle}" />
                                <StackPanel Grid.Row="1"
                                            Margin="5"
                                            Orientation="Horizontal">
                                    <Button Width="100"
                                            HorizontalAlignment="Left"
                                            Command="{Binding ClickFileCheckCommand}"
                                            Content="{DynamicResource utilCheck}"
                                            Style="{StaticResource MaterialDesignRaisedDarkButton}"
                                            ToolTip="{DynamicResource utilCheck}" />
                                    <TextBlock Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding FileLocked}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Margin="0,5,0,0"
                                BorderBrush="DimGray"
                                BorderThickness="3"
                                CornerRadius="5">
                            <Grid Background="{DynamicResource MaterialDesignToolBarBackground}">
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition MinHeight="65" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Margin="5"
                                           VerticalAlignment="Center"
                                           Text="{DynamicResource utilChooserTitle}" />
                                <Button Grid.Row="1"
                                        Width="100"
                                        Margin="5"
                                        HorizontalAlignment="Left"
                                        Command="{Binding ClickConnectCmd}"
                                        Content="{DynamicResource utilChooser}"
                                        Style="{StaticResource MaterialDesignRaisedDarkButton}"
                                        ToolTip="{DynamicResource utilChooser}" />
                                <TextBlock Grid.Row="2"
                                           Margin="5"
                                           Text="{Binding Connect}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                        <Border Margin="0,5,0,0"
                                BorderBrush="DimGray"
                                BorderThickness="3"
                                CornerRadius="5">
                            <Grid Background="{DynamicResource MaterialDesignToolBarBackground}">
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <TextBlock Margin="5"
                                               VerticalAlignment="Center"
                                               Text="{DynamicResource utilSerial}" />
                                    <Button Margin="2"
                                            Padding="7"
                                            Command="{Binding ClickSerialStartCmd}"
                                            Content="{DynamicResource utilStart}"
                                            Style="{StaticResource MaterialDesignRaisedDarkButton}"
                                            ToolTip="{DynamicResource utilStart}" />
                                    <Button Margin="2"
                                            Padding="7"
                                            Command="{Binding ClickSerialStopCmd}"
                                            Content="{DynamicResource utilStop}"
                                            Style="{StaticResource MaterialDesignRaisedDarkButton}"
                                            ToolTip="{DynamicResource utilStop}" />
                                    <ComboBox MinWidth="60"
                                              Margin="2"
                                              materialDesign:HintAssist.Hint="{DynamicResource utilComPort}"
                                              ItemsSource="{Binding ComPortList}"
                                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                              ToolTip="{DynamicResource utilComPort}">
                                        <ComboBox.SelectedItem>
                                            <Binding Mode="TwoWay"
                                                     Path="ComPort"
                                                     UpdateSourceTrigger="PropertyChanged">
                                                <Binding.ValidationRules>
                                                    <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                                </Binding.ValidationRules>
                                            </Binding>
                                        </ComboBox.SelectedItem>
                                        <ComboBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel />
                                            </ItemsPanelTemplate>
                                        </ComboBox.ItemsPanel>
                                    </ComboBox>
                                    <ComboBox MinWidth="10"
                                              Margin="2"
                                              materialDesign:HintAssist.Hint="{DynamicResource utilBaudRate}"
                                              ItemsSource="{Binding BaudRates}"
                                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                              ToolTip="{DynamicResource utilBaudRate}">
                                        <ComboBox.SelectedItem>
                                            <Binding Mode="TwoWay"
                                                     Path="BaudRate"
                                                     UpdateSourceTrigger="PropertyChanged">
                                                <Binding.ValidationRules>
                                                    <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                                </Binding.ValidationRules>
                                            </Binding>
                                        </ComboBox.SelectedItem>
                                        <ComboBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel />
                                            </ItemsPanelTemplate>
                                        </ComboBox.ItemsPanel>
                                    </ComboBox>
                                    <ComboBox MinWidth="60"
                                              Margin="2"
                                              materialDesign:HintAssist.Hint="{DynamicResource utilInterval}"
                                              ItemsSource="{Binding IntervalList}"
                                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                              ToolTip="{DynamicResource utilInterval}">
                                        <ComboBox.SelectedItem>
                                            <Binding Mode="TwoWay"
                                                     Path="Interval"
                                                     UpdateSourceTrigger="PropertyChanged">
                                                <Binding.ValidationRules>
                                                    <domain1:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                                </Binding.ValidationRules>
                                            </Binding>
                                        </ComboBox.SelectedItem>
                                        <ComboBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel />
                                            </ItemsPanelTemplate>
                                        </ComboBox.ItemsPanel>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock Grid.Row="1"
                                           Margin="15"
                                           HorizontalAlignment="Left"
                                           Text="{Binding SerMsg}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                    <Button Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Width="100"
                            Margin="5"
                            VerticalAlignment="Bottom"
                            Command="{Binding ClickCloseAppCommand}"
                            Content="{DynamicResource utilExit}"
                            Style="{StaticResource MaterialDesignRaisedDarkButton}"
                            ToolTip="{DynamicResource utilExit}" />
                </Grid>
            </materialDesign:DrawerHost>
        </Grid>
    </Grid>
</Window>
