<UserControl x:Class="GS.Utilities.Controls.WindowTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:main="clr-namespace:GS.Utilities.Main"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance main:MainWindowVm}"
             mc:Ignorable="d">
    <StackPanel Background="Black">
        <Grid>
            <StackPanel Margin="10,0,0,0"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                <Label VerticalAlignment="Bottom"
                       Content="GS Utilities"
                       FontSize="15"
                       Foreground="{DynamicResource PrimaryHueLightBrush}" />
                <Label VerticalAlignment="Bottom"
                       Content="{Binding Version}"
                       Foreground="{DynamicResource PrimaryHueLightBrush}" />
            </StackPanel>
            <StackPanel Margin="5,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button Width="30"
                        Height="30"
                        VerticalAlignment="Center"
                        Background="{x:Null}"
                        BorderBrush="{x:Null}"
                        Command="{Binding MinimizeWindowCommand}"
                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                        Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}">
                    <md:PackIcon Width="25"
                                 Height="25"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                 Kind="WindowMinimize" />
                </Button>
                <Button Width="30"
                        Height="30"
                        VerticalAlignment="Center"
                        Background="{x:Null}"
                        BorderBrush="{x:Null}"
                        Command="{Binding ClickCloseAppCommand}"
                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                        Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}">
                    <md:PackIcon Width="25"
                                 Height="25"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                 Kind="Power" />
                </Button>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
