<UserControl x:Class="GS.Utilities.Controls.Dialogs.ZipFilesDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:main="clr-namespace:GS.Utilities.Main"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance main:MainWindowVm}"
             mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TextBlock Margin="10,0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Text="{DynamicResource utilAccZipFiles}" />
        <StackPanel Grid.Row="1"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <Button Command="{Binding ClickAcceptZipDialogCommand}"
                    Content="{DynamicResource diaAccept}"
                    IsDefault="True"
                    Style="{DynamicResource MaterialDesignFlatButton}" />
            <Button Margin="8,0,0,0"
                    Command="{Binding CancelZipDialogCommand}"
                    Content="{DynamicResource diaCancel}"
                    IsCancel="True"
                    Style="{DynamicResource MaterialDesignFlatButton}" />
        </StackPanel>
    </Grid>
</UserControl>
